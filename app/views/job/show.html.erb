.timeline-progress {
  position: absolute;
  top: 1.5rem;
  left: 0;
  height: 3px;
  background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%);
  z-index: 2;
  transition: width 0.5s ease;
  box-shadow: 0 1px 2px rgba(59, 130, 246, 0.3);
