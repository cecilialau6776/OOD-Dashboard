<!DOCTYPE html>
<html lang="<%= Configuration.locale %>" style="font-size: 16px;">
<head>
  <title><%= content_for?(:title) ? yield(:title) : "Dashboard - #{OodAppkit.dashboard.title}" %></title>
  <%= favicon_link_tag "favicon.ico", href: OodAppkit.public.url.join("favicon.ico"), skip_pipeline: true %>

  <%= render partial: "shared/indexed_db_cache" %>
  <%= render partial: '/layouts/nav/styles', locals: { bg_color: @user_configuration.brand_bg_color, link_active_color:  @user_configuration.brand_link_active_bg_color } %>


  <!-- Lodash -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/lodash.js/4.17.21/lodash.min.js"></script>

  <!-- jQuery -->
  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://code.jquery.com/jquery-migrate-3.5.2.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jquery-ujs@1.2.3/src/rails.min.js"></script>

  <script>
    jQuery.migrateMute = true;
  </script>

  <!-- Popper -->
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" integrity="sha384-9/reFTGAW83EW2RDu2S0VKaIzap3H66lZH81PoYlFhbGU+6BZp6G7niu735Sk7lN" crossorigin="anonymous"></script>

  <!-- Bootstrap -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js" integrity="sha384-+sLIOodYLS7CIrQpBjl+C7nPvqq+FbNUBDunl/OZv93DB7Ln/533i8e/mZXLi/P+" crossorigin="anonymous"></script>

  <!-- Oboe -->
  <script src="https://cdn.jsdelivr.net/npm/oboe@2.1.5/dist/oboe-browser.min.js"></script>

  <!--Datatables.net-->
  <% if local_assigns[:datatables_version] == 'old' %>
    <link href="https://cdn.datatables.net/v/bs4/dt-1.10.24/sl-1.3.3/datatables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/v/bs4/dt-1.10.24/sl-1.3.3/datatables.min.js"></script>
  <% else %>
    <link href="https://cdn.datatables.net/v/bs4/dt-2.0.8/fh-4.0.1/r-3.0.2/sl-2.0.3/datatables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/v/bs4/dt-2.0.8/fh-4.0.1/r-3.0.2/sl-2.0.3/datatables.min.js"></script>
  <% end %>

  <!--Moment-->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.30.1/moment.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.45/moment-timezone-with-data.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/moment-duration-format/2.3.2/moment-duration-format.min.js"></script>

  <!--Font Awesome 5-->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.12.0/css/all.min.css" />

  <!-- SheetJS -->
  <script lang="javascript" src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>

  <!--Chartjs-->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-stacked100@1.0.0"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-chart-treemap@2.3.1/dist/chartjs-chart-treemap.min.js"></script>

  <!-- Patternomaly -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/patternomaly/1.3.2/patternomaly.min.js"></script>

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

  <!-- Data Confirm Modal -->
  <script src="https://cdn.jsdelivr.net/npm/data-confirm-modal@1.6.2/vendor/assets/javascripts/data-confirm-modal.min.js"></script>

  <!-- Handlebars -->
  <script src="https://cdn.jsdelivr.net/npm/handlebars@4.7.8/dist/handlebars.min.js"></script>

  <!-- Highlight.js -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/bash.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/python.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/r.min.js"></script>

  <!-- Date Range Picker -->
  <script src="https://cdn.jsdelivr.net/npm/daterangepicker@3.1.0/daterangepicker.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daterangepicker@3.1.0/daterangepicker.min.css">

  <!-- (Legacy) Sprockets -->
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_include_tag "application" %>

  <!--Toastr-->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

  <%= render partial: "layouts/constants" %>
  <%= render partial: "layouts/util" %>

  <style>
    /* Base styles */
    :root {
      --main-bg-color: #f8f9fa;
    }

    body {
      background-color: var(--main-bg-color);
      padding-top: 0;
    }

    /* Menu toggle button styles - remove all interactions */
    .menu-toggle {
      padding: 8px !important;
      background: none;
      border: none;
      cursor: pointer;
      margin-left: 0.25rem;
      margin-right: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      -webkit-appearance: none;
      -moz-appearance: none;
      transition: transform 0.2s ease;
    }

    /* Increase icon size */
    .menu-toggle i {
      font-size: 1.15rem;
    }

    /* Add hover and click animations */
    .menu-toggle:hover {
      transform: scale(1.1);
    }

    .menu-toggle:active {
      transform: scale(0.85);
    }

    /* Pulse animation for the menu toggle */
    @keyframes togglePulse {
      0% {
        box-shadow: 0 0 0 0 rgba(74, 144, 226, 0.7);
        transform: scale(var(--scale, 1));
      }
      70% {
        box-shadow: 0 0 0 15px rgba(74, 144, 226, 0);
        transform: scale(var(--scale, 1));
      }
      100% {
        box-shadow: 0 0 0 0 rgba(74, 144, 226, 0);
        transform: scale(var(--scale, 1));
      }
    }

    /* Class to apply the pulse animation */
    .menu-toggle-pulse {
      animation: togglePulse 1.5s infinite;
      border-radius: 50%;
      transform-origin: center;
      --scale: 1;
    }

    /* Update pulse animation to work with hover/click states */
    .menu-toggle-pulse:hover {
      --scale: 1.1;
    }

    .menu-toggle-pulse:active {
      --scale: 0.85;
    }

    #userDropdown + .dropdown-menu .dropdown-item:active,
    #userDropdown + .dropdown-menu .dropdown-item:focus {
      background-color: #f0f2f5;
      color: #444;
    }

    #userDropdown + .dropdown-menu .dropdown-item:active i,
    #userDropdown + .dropdown-menu .dropdown-item:focus i {
      color: inherit;
    }

    /* Update dropdown menu styles */
    #userDropdown + .dropdown-menu {
      position: fixed !important;
      top: 60px !important;
      transform: none !important;
      z-index: 1045;
    }

    @media (min-width: 992px) {
      .nav-link-styled {
        padding: 8px 10px !important;
        border-radius: 6px !important;
        color: #444 !important;
        transition: all 0.2s ease !important;
        text-decoration: none !important;
      }

      .nav-link-styled:hover {
        background-color: #f8f9fa !important;
        color: #000 !important;
        text-decoration: none !important;
      }

      .nav-link-styled:focus-visible {
        background-color: #f0f2f5 !important;
        color: #000 !important;
        text-decoration: none !important;
        outline: 2px solid #4A90E2 !important;
        outline-offset: 2px !important;
      }

      .nav-link-styled:active {
        background-color: #e8eaed !important;
        color: #000 !important;
        text-decoration: none !important;
        transform: scale(0.98);
      }

      .nav-link-styled i {
        margin-right: 0.5rem;
      }
    }
  </style>

  <%= csrf_meta_tags %>

  <%= yield :head %>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="turbolinks-root" content="<%= ENV["RAILS_RELATIVE_URL_ROOT"] || "/" %>">
</head>
<body>
  <header>
    <nav class="navbar navbar-expand-md shadow-sm navbar-color navbar-<%= @user_configuration.navbar_type %>">
      <ul class="navbar-nav w-100 align-items-center" role="menubar">
        <%= render partial: 'layouts/nav/logo' %>
      
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar" aria-controls="navbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbar">
          <% if @nav_bar.empty? %>
            <%= render partial: 'layouts/nav/featured_apps' %>
            <%= render partial: 'layouts/nav/group', collection: @nav_groups %>
            <%= render partial: 'layouts/nav/sessions', nav_groups: @nav_groups if Configuration.app_development_enabled? || @nav_groups.any?(&:has_batch_connect_apps?) %>
            <%= render partial: 'layouts/nav/all_apps' if @user_configuration.show_all_apps_link %>
          <% else %>
            <%= render partial: 'layouts/nav/custom_navigation', locals: { navigation: @nav_bar }%>
          <% end %>

          <!-- add some space between nav_bar and help_menu -->
          <div class="ms-auto"></div>

          <% if @help_bar.empty? %>
            <%= render partial: 'layouts/nav/develop_dropdown' %>
            <%= render partial: 'layouts/nav/help_dropdown' %>
            <%= render partial: 'layouts/nav/user' %>
            <%= render partial: 'layouts/nav/log_out' %>
          <% else %>
            <%= render partial: 'layouts/nav/custom_navigation', locals: { navigation: @help_bar, menu_alignment: 'dropdown-menu-end' }%>
          <% end %>
        </div>
      </ul>
    </nav>
  </header>

  <div class="container content px-lg-4" role="main" id="main-container">
    <div class="row" id="warnings"></div>
    
    <script type="text/coffee-script-template" id="js-alert-danger-template">
      <div class="alert alert-danger alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert">
          <span aria-hidden="true">&times;</span>
          <span class="sr-only">Close</span>
        </button>
        ALERT_MSG
      </div>
    </script>

    <% if alert %>
      <div class="alert alert-danger alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert">
          <span aria-hidden="true">&times;</span>
          <span class="sr-only">Close</span>
        </button>
        <%= alert %>
      </div>
    <% end %>

    <% if notice %>
      <div class="alert alert-success" role="alert">
        <button type="button" class="close" data-dismiss="alert">
          <span aria-hidden="true">&times;</span>
          <span class="sr-only">Close</span>
        </button>
        <%= notice %>
      </div>
    <% end %>

    <%= yield %>
  </div>

  <%= render "layouts/footer" %>

  <script>
    function getValuesByKey(data, key) {
      return data.map(item => item[key]);
    }

    function showWarning(id, body, showClose) {
      const alertHtml = `
      <div class="col-12" id="${id}">
          <div class="alert alert-danger ${showClose ? "alert-dismissible fade show" : ""}" role="alert" style="border-radius: 25px; box-shadow: 0 0 5px #ccc;">
              ${body}
              ${showClose ? `
              <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
              ` : ""}
          </div>
      </div>
      `;

      if ($(`#warnings #${id}`).length > 0) {
          $(`#warnings #${id}`).remove();
      }
      $("#warnings").append(alertHtml);
    }

    // Originally from https://stackoverflow.com/a/16348977
    function stringToColor(str) {
      let hash = 0;
      str.split('').forEach(char => {
          hash = char.charCodeAt(0) + ((hash << 5) - hash);
      })
      let color = '#';
      for (let i = 0; i < 3; i++) {
          const value = (hash >> (i * 8)) & 0xff;
          color += value.toString(16).padStart(2, '0');
      }
      return color;
    }

    $(document).ready(function() {
      const sidebar = $('.sidebar');
      const toggleButton = $('#sidebar-toggle');
      const mainContainer = $('#main-container');
      
      toggleButton.click(function() {
        const isExpanded = sidebar.hasClass('active');
        sidebar.toggleClass('active');
        
        // Update ARIA attributes
        toggleButton.attr('aria-expanded', !isExpanded);
        sidebar.attr('aria-hidden', isExpanded);
      });

      // Close sidebar when clicking outside
      mainContainer.on('click', function(e) {
        if (sidebar.hasClass('active')) {
          sidebar.removeClass('active');
          toggleButton.attr('aria-expanded', 'false');
          sidebar.attr('aria-hidden', 'true');
        }
      });

      // Add keyboard navigation
      $(document).keyup(function(e) {
        if (e.key === "Escape" && sidebar.hasClass('active')) {
          sidebar.removeClass('active');
          toggleButton.attr('aria-expanded', 'false');
          sidebar.attr('aria-hidden', 'true');
          toggleButton.focus();
        }
      });

      // Auto-open submenus that contain active items
      $('.submenu-item.active').each(function() {
        const submenu = $(this).closest('.submenu');
        submenu.show();
        submenu.prev('.nav-link').attr('aria-expanded', 'true');
      });

      // Keep submenus open when clicking inside them
      $('.submenu').on('click', function(e) {
        e.stopPropagation();
      });

      // Check if this is the first visit
      if (!localStorage.getItem('hasOpenedSidebarBefore')) {
        // Add pulse animation
        $('#sidebar-toggle').addClass('menu-toggle-pulse');
        
        // Remove pulse and tooltip after click
        const removeFirstTimeEffects = () => {
          $('#sidebar-toggle').removeClass('menu-toggle-pulse');
          localStorage.setItem('hasOpenedSidebarBefore', 'true');
        };

        // Remove effects when clicked
        $('#sidebar-toggle').one('click', function() {
          // Small delay to ensure the animation is visible during the click
          setTimeout(removeFirstTimeEffects, 100);
        });
      }
    });

    function toggleSubmenu(element) {
      event.preventDefault();
      const submenu = element.nextElementSibling;
      const isExpanded = element.getAttribute('aria-expanded') === 'true';
      
      // Close all other submenus
      document.querySelectorAll('.submenu').forEach(menu => {
        if (menu !== submenu) {
          menu.style.display = 'none';
          menu.previousElementSibling.setAttribute('aria-expanded', 'false');
        }
      });
      
      // Toggle current submenu
      submenu.style.display = isExpanded ? 'none' : 'block';
      element.setAttribute('aria-expanded', !isExpanded);
    }

    // Close submenus when clicking outside
    document.addEventListener('click', function(event) {
      if (!event.target.closest('.nav-item')) {
        document.querySelectorAll('.submenu').forEach(menu => {
          // Don't close submenu if it contains an active item
          if (!menu.querySelector('.submenu-item.active')) {
            menu.style.display = 'none';
            menu.previousElementSibling.setAttribute('aria-expanded', 'false');
          }
        });
      }
    });

    // Initialize submenus - run this after DOM is loaded
    document.addEventListener('DOMContentLoaded', function() {
      // Find any submenu items that are marked as active
      document.querySelectorAll('.submenu-item.active').forEach(activeItem => {
        const submenu = activeItem.closest('.submenu');
        if (submenu) {
          // Show the submenu
          submenu.style.display = 'block';
          // Update the toggle button state
          const toggleButton = submenu.previousElementSibling;
          if (toggleButton) {
            toggleButton.setAttribute('aria-expanded', 'true');
          }
        }
      });
    });

    document.addEventListener('DOMContentLoaded', function() {
      const restartLinks = document.querySelectorAll("a.nav-link.submenu-item");
      for (const restartLink of restartLinks) {
        if (restartLink.hasAttribute("href") && restartLink.getAttribute("href").includes("/nginx/stop?redir=") && restartLink?.querySelector("i.fas.fa-sync")) {
          const restartIcon = restartLink.querySelector("i.fas.fa-sync");
          restartLink.addEventListener('click', function(e) {
            restartIcon.classList.add('icon-spin');
          });
        }
      }
    });

    $(document).ready(function() {
      const toggle = $('#navLocationToggle');
      
      // Match initial state to what we set in the blocking script
      const initialState = localStorage.getItem('showInTop') === 'false';
      toggle.prop('checked', initialState);
      
      toggle.change(function() {
        const sidebarOnly = $(this).is(':checked');
        if (!sidebarOnly) {
          document.documentElement.classList.remove('show-in-sidebar');
        } else {
          document.documentElement.classList.add('show-in-sidebar');
        }
        localStorage.setItem('showInTop', !sidebarOnly);
      });
    });
  </script>
</body>
</html>
</html>
