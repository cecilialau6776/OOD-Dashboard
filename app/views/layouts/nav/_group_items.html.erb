<% OodAppGroup.groups_for(apps: group.apps, group_by: :subcategory, sort: group.sort).each_with_index do |g, index| %>
  <%= content_tag(:div, "", class: ["dropdown-divider"], role: "separator") if index > 0 %>
  <%= content_tag(:div, g.title, class: ["dropdown-header"]) unless g.title.empty? %>
  <% g.apps.each do |app| %>
    <% app.links.each do |link| %>
      <%= link_to link.url.to_s,
          title: link.title,
          class: "nav-link submenu-item #{current_app_url?(link.url) ? 'active' : ''}",
          target: link.new_tab? ? "_blank" : nil do %>
        <%= icon_tag(link.icon_uri, classes: []) %>
        <span>
          <%= link.title %>
          <% if link.subtitle.present? %>
            <small class="d-block text-muted"><%= link.subtitle %></small>
          <% end %>
        </span>
      <% end %>
    <% end %>
  <% end %>
<% end %>