<h3 class="font-weight-bold mb-3 d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <i class="fas fa-layer-group text-warning"></i>
        <span class="mx-2">Accounts</span>
        <a href="https://www.rcac.purdue.edu/knowledge/gautschi/run/slurm/queues" 
           class="ms-1" 
           style="color: #6c757d; font-size: 1.1rem;"
           data-toggle="tooltip" 
           title="Click to learn more about accounts and queues on Gautschi"
           aria-label="Documentation about accounts and queues on Gautschi"
           target="_blank">
            <i class="fas fa-info-circle" aria-hidden="true"></i>
        </a>
    </div>
    <button onclick="load_account_list(true)" 
            class="btn btn-sm action-btn"
            style="background: hsl(0 0% 100%); border: 1px solid hsl(214.3 31.8% 91.4%); color: hsl(222.2 84% 4.9%); border-radius: 8px; padding: 0.375rem 0.5rem; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
            onmouseover="this.style.background='hsl(210 40% 98%)'; this.style.borderColor='hsl(214.3 31.8% 85%)'"
            onmouseout="this.style.background='hsl(0 0% 100%)'; this.style.borderColor='hsl(214.3 31.8% 91.4%)'">
        <i class="fas fa-sync-alt"></i>
    </button>
</h3>
<div style="border-bottom: 1px solid rgba(0,0,0,0.1);" class="mb-3"></div>
<div id="account_list_card_content"></div>

<style>
  .btn:focus,
  .btn:active:focus,
  .btn.active:focus {
    outline: none !important;
    box-shadow: none !important;
  }

  .action-btn:active {
    transform: translateY(1px);
    background: hsl(210 40% 95%) !important;
    border-color: hsl(214.3 31.8% 80%) !important;
  }
</style>

<script defer>
    function download_balance_summary(allocation, type, total_sus_used, total_sus_limit) {
        var BALANCE_SUMMARY_COLUMNS = ["Username", "SUs Used", "SU Limit"];

        const $button = $(`#${allocation}-export-dropdown-button`);
        const $icon = $button.find('i.fas');
        
        // Disable the button and save original icon class
        $button.prop('disabled', true);
        const originalIconClass = $icon.attr('class');
        
        // Replace icon with spinner
        $icon.removeClass().addClass('spinner-border spinner-border-sm');

        fetchWithCache(`<%= url_for controller: "api/gpu_hour_summary", action: "get" %>?allocation=${encodeURIComponent(allocation)}`, {
            forceRefresh: false,
            cacheDuration: 10 * 60 * 1000  // Cache for 10 minutes
        }).then(data => {
            var EXPORT_TYPES = {"CSV": "csv", "Excel": "xlsx"};
            if (data.length === 0) {
                toastr.error("No data to export");
            } else if (Object.keys(EXPORT_TYPES).includes(type)) {
                toastr.info(`Exporting ${data.length} row(s) as ${type}...`);
                
                // Create the export data with total SUs in a table format
                const exportData = [
                    ["Allocation", "Total GPU Hours Used", "Total GPU Hours Limit", "Generated At (UTC)"],
                    [allocation, 
                     total_sus_used.toLocaleString(), 
                     total_sus_limit === "No limit" ? "No limit" : total_sus_limit.toLocaleString(),
                     new Date().toISOString().replace('T', ' ').replace(/\.\d+Z$/, ' UTC')
                    ],
                    [], // Empty row for spacing
                    BALANCE_SUMMARY_COLUMNS,
                    ...data.map(row => Object.values(row))
                ];
                
                const worksheet = XLSX.utils.aoa_to_sheet(exportData);
                var workbook = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(workbook, worksheet, 'Sheet1');
                XLSX.writeFile(workbook, `gautschi_service_units_${allocation}_${Date.now()}.${EXPORT_TYPES[type]}`, { compression: true });
            } else {
                toastr.error("Invalid export file type");
            }
        }).catch(res => {
            toastr.error("Failed to export allocation service unit usage!");
        }).finally(() => {
            // Restore original icon and re-enable button
            $icon.removeClass().addClass(originalIconClass);
            $button.prop('disabled', false);
        });
    }

    function formatLargeNumber(num, decimals = 1) {
        const fullNum = num.toLocaleString(undefined, {maximumFractionDigits: 2});
        if (num >= 1000000) {
            const formatted = (num/1000000).toFixed(decimals);
            const isExact = num === Math.round(num/1000000) * 1000000;
            const style = isExact ? '' : ' style="border-bottom: 1px dotted #6c757d; cursor: help" data-toggle="tooltip" data-trigger="hover click"';
            return `<span${style} title="${isExact ? '' : fullNum}">${formatted.endsWith('.0') ? formatted.slice(0, -2) : formatted}M</span>`;
        }
        if (num >= 1000) {
            const formatted = (num/1000).toFixed(decimals);
            const isExact = num === Math.round(num/1000) * 1000;
            const style = isExact ? '' : ' style="border-bottom: 1px dotted #6c757d; cursor: help" data-toggle="tooltip" data-trigger="hover click"';
            return `<span${style} title="${isExact ? '' : fullNum}">${formatted.endsWith('.0') ? formatted.slice(0, -2) : formatted}K</span>`;
        }
        return num.toLocaleString(undefined, {maximumFractionDigits: 2});
    }

    function load_account_list(forceRefresh = false) {
        const loadingHtml = `
        <div class="d-flex flex-column align-items-center justify-content-center h-100">
            <div class="position-relative mb-3">
                <div class="spinner-border text-secondary" style="width: 3rem; height: 3rem;" role="status">
                    <span class="sr-only">Loading...</span>
                </div>
            </div>
            <p class="text-muted mb-0">Loading account data...</p>
        </div>
        `;
        
        $("#account_list_card_content").html(loadingHtml);

        return fetchWithCache(`<%= url_for controller: "api/account_list", action: "get" %>`, {
            forceRefresh,
            cacheDuration: 1 * 60 * 1000  // Cache for 1 minute
        }).then(data => {
            const tableHtml = data.length === 0 ? '<div class="h5 mb-2">No allocations available</div>' : data.map((row) => {
                const percentCPU = (row.cpu_running / row.cpu_total) * 100 || 0;
                const percentGPU = (row.gpu_used / row.gpu_total) * 100 || 0;

                const barHtml = `
                <div class="mb-3">
                    <div class="pb-3" style="border-bottom: 1px solid rgba(0,0,0,0.1);">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <div class="h5 mb-0">
                                ${row.account}
                            </div>
                            <div class="btn-group">
                                <button id="${row.account}-export-dropdown-button" 
                                    class="btn btn-sm action-btn dropdown-toggle" 
                                    style="background: hsl(0 0% 100%); border: 1px solid hsl(214.3 31.8% 91.4%); color: hsl(222.2 84% 4.9%); border-radius: 8px; padding: 0.375rem 0.75rem; font-weight: 500; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); font-size: 0.875rem;"
                                    onmouseover="this.style.background='hsl(210 40% 98%)'; this.style.borderColor='hsl(214.3 31.8% 85%)'"
                                    onmouseout="this.style.background='hsl(0 0% 100%)'; this.style.borderColor='hsl(214.3 31.8% 91.4%)'"
                                    data-toggle="dropdown" 
                                    aria-expanded="false">
                                    <i class="fas fa-download"></i> <span class="d-none d-sm-inline">Export</span>
                                </button>
                                <div class="gpu-hour-export-dropdown dropdown-menu dropdown-menu-right shadow-sm" 
                                    aria-labelledby="${row.account}-export-dropdown-button" 
                                    data-account="${row.account}"
                                    data-total-gpu-hours-used="${row.gpu_used}"
                                    data-total-gpu-hours-limit="${row.gpu_total}">
                                    <button class="dropdown-item text-body" style="font-size: 0.875rem;">
                                        <i class="fas fa-file-csv"></i> CSV
                                    </button>
                                    <button class="dropdown-item text-body" style="font-size: 0.875rem;">
                                        <i class="fas fa-file-excel"></i> Excel
                                    </button>
                                </div>
                            </div>
                        </div>
                        ${row.cpu_total != 0 ? `
                        <div class="d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="text-nowrap" style="font-size: 1rem;">
                                    ${row.cpu_total === "No limit" ? 
                                        `<b>${formatLargeNumber(+row.cpu_running)}</b> CPUs in use <span class="text-muted">(No CPU limit)</span>` :
                                        `<b>${formatLargeNumber(+row.cpu_running)}</b> / 
                                        <b>${formatLargeNumber(+row.cpu_total)}</b> CPUs in use
                                        <span class="text-muted">
                                            (<b>${formatLargeNumber(+row.cpu_queue)}</b> queued)
                                        </span>`
                                    }
                                </div>
                                <div class="text-muted ml-2 text-nowrap" style="min-width: 3rem; text-align: right; font-size: 1rem;">
                                    ${row.cpu_total === "No limit" ? '' : `${Math.round(percentCPU)}%`}
                                </div>
                            </div>
                            <div class="progress mt-2" style="height: 8px; border-radius: 4px;">
                                <div class="progress-bar" role="progressbar" 
                                    style="background-color: ${row.cpu_total === "No limit" ? '#28a745' : 
                                        percentCPU > 95 ? '#dc3545' : 
                                        percentCPU > 75 ? '#ffc107' : '#28a745'}; 
                                    width: 0; transition: width 0.6s ease-in-out;" 
                                    aria-valuenow="${row.cpu_total === "No limit" ? 0 : percentCPU}" 
                                    aria-valuemin="0" 
                                    aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                        ` : ''}
                        ${row.gpu_total != 0 ? `
                            <div class="d-flex flex-column mt-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-nowrap" style="font-size: 1rem;">
                                        ${row.gpu_total === "No limit" ? 
                                            `<b>${formatLargeNumber(+row.gpu_used)}</b> <span class="text-muted">(No GPU hour limit)</span>` :
                                            `<b>${formatLargeNumber(+row.gpu_used)}</b> / 
                                            <b>${formatLargeNumber(+row.gpu_total)}</b> GPU hours used
                                            <span class="text-muted">
                                                (user: <b>${formatLargeNumber(+row.user_gpu_used)}</b>)
                                            </span>
                                            `
                                        }
                                    </div>
                                    <div class="text-muted ml-2 text-nowrap" style="min-width: 3rem; text-align: right; font-size: 1rem;">
                                        ${row.gpu_total === "No limit" ? '' : `${Math.round(percentGPU)}%`}
                                    </div>
                                </div>
                                <div class="progress mt-2" style="height: 8px; border-radius: 4px;">
                                    <div class="progress-bar" role="progressbar" 
                                        style="background-color: ${row.gpu_total === "No limit" ? '#28a745' : 
                                            percentGPU > 95 ? '#dc3545' : 
                                            percentGPU > 75 ? '#ffc107' : '#28a745'}; 
                                        width: 0; transition: width 0.6s ease-in-out;" 
                                        aria-valuenow="${row.gpu_total === "No limit" ? 0 : percentGPU}" 
                                        aria-valuemin="0" 
                                        aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        ` : ''}
                    </div>
                </div>
                `;
                return barHtml;
            }).join("");

            $("#account_list_card_content").html(tableHtml);
            // Add small delay to trigger animation
            setTimeout(() => {
                $('.progress-bar').each(function() {
                    $(this).css('width', $(this).attr('aria-valuenow') + '%');
                });
            }, 50);

            $('[data-toggle="tooltip"]').tooltip({
                boundary: 'window',
                trigger: 'hover click'
            }).on('show.bs.tooltip', function() {
                // Hide all other tooltips
                $('[data-toggle="tooltip"]').not(this).tooltip('hide');
            });

            // Hide tooltips when clicking anywhere else on the document
            $(document).on('click', function(event) {
                if (!$(event.target).closest('[data-toggle="tooltip"]').length) {
                    $('[data-toggle="tooltip"]').tooltip('hide');
                }
            });

            $('div.gpu-hour-export-dropdown .dropdown-item').on("click", function() {
                const $dropdown = $(this).parent();
                const allocation = $dropdown.data("account");
                const total_gpu_hours_used = $dropdown.data("total-gpu-hours-used");
                const total_gpu_hours_limit = $dropdown.data("total-gpu-hours-limit");
                // Extract just the text content, removing any HTML and trimming whitespace
                const exportType = $(this).text().trim();
                download_balance_summary(allocation, exportType, total_gpu_hours_used, total_gpu_hours_limit);
            });
        }).catch(res => {
            const errorHtml = `
            <div class="d-flex flex-column align-items-center justify-content-center h-100 py-3">
                <div class="text-danger mb-3">
                    <i class="fas fa-exclamation-circle fa-2x"></i>
                </div>
                <h5 class="mb-2">Unable to Load Account List</h5>
                <p class="text-muted small mb-3">There was a problem retrieving your account information</p>
                <button class="btn btn-sm action-btn" 
                        style="background: hsl(0 0% 100%); border: 1px solid hsl(214.3 31.8% 91.4%); color: hsl(222.2 84% 4.9%); border-radius: 8px; padding: 0.5rem 1rem; font-weight: 500; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                        onmouseover="this.style.background='hsl(210 40% 98%)'; this.style.borderColor='hsl(214.3 31.8% 85%)'"
                        onmouseout="this.style.background='hsl(0 0% 100%)'; this.style.borderColor='hsl(214.3 31.8% 91.4%)'"
                        onclick="load_account_list(true)">
                    <i class="fas fa-sync-alt mr-1"></i> Retry
                </button>
            </div>
            `;

            $("#account_list_card_content").html(errorHtml);
        });
    }
</script>